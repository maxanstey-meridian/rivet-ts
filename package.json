{
  "name": "rivet-ts",
  "version": "0.7.0",
  "private": true,
  "description": "TypeScript contract extractor for Rivet",
  "keywords": [
    "codegen",
    "contracts",
    "openapi",
    "rivet",
    "typescript"
  ],
  "license": "MIT",
  "bin": {
    "rivet-reflect-ts": "./dist/interfaces/cli/main.js",
    "rivet-ts": "./dist/interfaces/cli/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "lint": "oxlint src/ tests/",
    "lint:fix": "oxlint --fix src/ tests/",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "hono": "^4.12.14",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.24.0"
}

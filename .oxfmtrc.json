{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "ignorePatterns": ["dist/**", "node_modules/**", ".plans/**"],
  "sortImports": {
    "enabled": true,
    "groups": [
      ["builtin", "external"],
      ["internal", "subpath"],
      ["parent", "sibling", "index"]
    ],
    "internalPattern": ["#*", "@/**", "~/**"],
    "newlinesBetween": false,
    "order": "asc",
    "ignoreCase": true
  }
}
